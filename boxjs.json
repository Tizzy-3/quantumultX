          "desc": "可选。没有 Cookie 时用于账号密码登录。"
        },
        {
          "id": "QX_SIGNIN_IMYAI_JWT",
          "name": "IMYAI JWT",
          "val": "",
          "type": "textarea",
          "desc": "通常由 qx_cookie_capture.js 自动写入。"
        },
        {
          "id": "QX_SIGNIN_KINGDEE_COOKIE",
          "name": "金蝶 Cookie",
          "val": "",
          "type": "textarea",
          "desc": "通常由 qx_cookie_capture.js 自动写入。"
        },
        {
          "id": "QX_SIGNIN_KINGDEE_CSRF_TOKEN",
          "name": "金蝶 CSRF Token",
          "val": "",
