      "settings": [
        {
          "id": "QX_SIGNIN_WECOM_WEBHOOK_URL",
          "name": "企业微信 Webhook",
          "val": "",
          "type": "text",
          "desc": "可选。填写企业微信机器人 webhook，不填则只发 Quantumult X 通知。"
        },
        {
          "id": "QX_SIGNIN_IMYAI_AES_KEY_B64",
          "name": "IMYAI AES Key",
          "val": "",
          "type": "text",
          "desc": "必填。IMYAI 加密请求使用的 AES base64 key。"
        },
        {
          "id": "QX_SIGNIN_IMYAI_HMAC_KEY_B64",
          "name": "IMYAI HMAC Key",
          "val": "",
          "type": "text",
          "desc": "必填。IMYAI 请求签名使用的 HMAC base64 key。"
        },
        {
          "id": "QX_SIGNIN_DEBUG",
          "name": "调试日志",
          "val": "false",
          "type": "boolean",
          "desc": "开启后会在 Quantumult X 日志里输出请求重试、部分失败原因等信息。"
        },
        {
          "id": "QX_SIGNIN_REQUEST_TIMEOUT_MS",
          "name": "请求超时毫秒",
          "val": "10000",
          "type": "number",
          "desc": "单个请求超时时间，默认 10000。"
        },
        {
          "id": "QX_SIGNIN_REQUEST_RETRIES",
          "name": "请求重试次数",
          "val": "2",
          "type": "number",
          "desc": "请求失败后的重试次数，默认 2，最大 5。"
        },
        {
          "id": "QX_SIGNIN_HASHIQI_COOKIE",
          "name": "哈士奇 Cookie",
          "val": "",
          "type": "textarea",
          "desc": "通常由 qx_cookie_capture.js 自动写入。"
        },
        {
          "id": "QX_SIGNIN_HASHIQI_USERNAME",
          "name": "哈士奇账号",
          "val": "",
          "type": "text",
          "desc": "可选。没有 Cookie 时用于账号密码登录。"
        },
        {
          "id": "QX_SIGNIN_HASHIQI_PASSWORD",
          "name": "哈士奇密码",
          "val": "",
