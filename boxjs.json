      "icons": [
        "https://raw.githubusercontent.com/Tizzy-3/quantumultX/refs/heads/main/To-do%20.png",
        "https://raw.githubusercontent.com/Tizzy-3/quantumultX/refs/heads/main/To-do%20.png"
      ],
      "keys": [
        "QX_SIGNIN_HASHIQI_COOKIE",
        "QX_SIGNIN_HASHIQI_USERNAME",
        "QX_SIGNIN_HASHIQI_PASSWORD",
        "QX_SIGNIN_IMYAI_JWT",
        "QX_SIGNIN_IMYAI_AES_KEY_B64",
        "QX_SIGNIN_IMYAI_HMAC_KEY_B64",
        "QX_SIGNIN_KINGDEE_COOKIE",
        "QX_SIGNIN_KINGDEE_CSRF_TOKEN",
        "QX_SIGNIN_KINGDEE_PRODUCT_LINE_ID",
        "QX_SIGNIN_WECOM_WEBHOOK_URL",
        "QX_SIGNIN_CRYPTOJS_URL",
        "QX_SIGNIN_DEBUG",
        "QX_SIGNIN_REQUEST_TIMEOUT_MS",
        "QX_SIGNIN_REQUEST_RETRIES"
